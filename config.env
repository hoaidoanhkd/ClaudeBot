# ClaudeBot Agent Config
# Edit this file to configure your project

PROJECT_NAME="YourProject"
PROJECT_PATH="$HOME/Desktop/Projects/YourProject"
GITHUB_REPO="user/YourProject"
PROJECT_TYPE="generic"
AGENTS="coordinator,coder,reviewer"
LOG_DIR="$HOME/logs"
# Active channel: "telegram" or "discord" (only 1 at a time)
# Managed by install.sh and /channel command — stored in ~/agents/active-channel.txt
TELEGRAM_CHAT_ID="your-chat-id"

# Performance tuning
# Autocompact at 80% context (set in ~/.claude/settings.json env)
# On-demand agents (QA, Researcher) use --bare for 10x faster startup
# On-demand agents use isolation: "worktree" for sandboxed execution

# Daemon intervals (used when scripts are available)
WATCHDOG_INTERVAL=30
KEEPALIVE_INTERVAL=60
CI_MONITOR_INTERVAL=120
GO_LOOP_DELAY=30
